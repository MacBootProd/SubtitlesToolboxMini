import { Button, VerticalBox, HorizontalBox, LineEdit, ComboBox, ScrollView, } from "std-widgets.slint";

export global Theme {
    in-out property <bool> is_dark: true;
    out property <color> brand-blue: #3873d5;
    out property <color> background: is_dark ? #171d26 : #f5f6f8;
    out property <color> surface: is_dark ? #232a35 : #ffffff;
    out property <color> text-main: is_dark ? #e2e8f0 : #1e293b;
    out property <color> text-muted: is_dark ? #94a3b8 : #64748b;
    out property <color> border: is_dark ? #454d59 : #cbd5e1;
    out property <color> input-bg: is_dark ? #1a202a : #fcfcfc;
    out property <color> success: #4ade80; out property <color> error: #f87171;
    out property <color> hover-blue: #4a85e7; out property <color> pressed-blue: #2a62c4;
}
// --- STYLES CATALOGUE ---
export component AppTitle inherits Text { font-size: 28px; font-weight: 800; color: Theme.brand-blue; horizontal-alignment: center; }
export component BasicText inherits Text { color: Theme.text-main; font-size: 14px; }
export component MutedText inherits Text { color: Theme.text-muted; font-size: 13px; font-italic: true; }
export component BlueBoldText inherits Text { color: Theme.brand-blue; font-size: 18px; font-weight: 800; }
export component SectionTitle inherits Text { color: Theme.brand-blue; font-size: 16px; font-weight: 700; }
export component StatusText inherits Text { font-size: 12px; } 
export component ResultText inherits Text { color: Theme.success; font-size: 14px; font-weight: 700; horizontal-alignment: center; }
export component IconEmoji inherits Text { color: Theme.text-main; font-size: 20px; }
export component LabelText inherits Text { color: Theme.text-main; font-weight: 600; font-size: 14px; vertical-alignment: center; }
export component ButtonText inherits Text { color: Theme.text-main; font-weight: 700; font-size: 14px; }
// --- CustomLineEdit ---
export component CustomLineEdit inherits Rectangle {
    in-out property <string> text <=> input.text; in-out property <bool> enabled: true; callback edited <=> input.edited;
    height: 32px; background: Theme.input-bg; border-width: 1px; border-radius: 4px; border-color: input.has-focus ? Theme.brand-blue : Theme.border; clip: true;
    input := TextInput {x: 5px; y: 7px; width: parent.width - 10px; height: parent.height - 14px; font-size: 14px; enabled: root.enabled; color: Theme.text-main; single-line: true;}
}
// --- Reading Box ---
export component ReadOnlyBox inherits Rectangle {
    in-out property <string> text;
    background: Theme.input-bg; border-width: 1px; border-color: Theme.border; border-radius: 4px;
    VerticalBox { 
        padding: 8px; 
        Text { 
            text: root.text; 
            color: Theme.text-main; 
            font-size: 14px; 
            wrap: word-wrap;
        } 
    }
}
// --- TAB ---
export component TabButton inherits Rectangle {
    in-out property <string> text; in-out property <bool> active: false; callback clicked;
    width: 220px; height: 40px;
    // Gestion dynamique du fond au Hover (Gris clair selon le mode)
    background: Theme.is-dark ? (ta.has-hover ? #2e2e2e : transparent) : (ta.has-hover ? #f0f0f0 : transparent);
    // Arrondi uniquement sur les coins supérieurs (Top-Left et Top-Right)
    border-top-left-radius: 4px; border-top-right-radius: 4px;
    // Simulation des bordures latérales et supérieures de 2px
    Rectangle { width: 100%; height: 100%; border-width: 2px; border-color: Theme.border; border-top-left-radius: 4px; border-top-right-radius: 4px; }
    // Ligne bleue inférieure masquant la bordure si l'onglet est sélectionné
    if (root.active) : Rectangle { y: parent.height - 3px; height: 3px; background: Theme.brand-blue; }
    
    BasicText { 
        text: root.text; horizontal-alignment: center; vertical-alignment: center;
        color: root.active ? Theme.brand-blue : Theme.text-main; font-size: 18px; font-weight: 700;
    }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}
// --- WIDGETS ---
export component CustomCheckBox inherits HorizontalBox {
    in-out property <string> text;
    in-out property <bool> checked;
    callback toggled; 
    spacing: 10px; padding: 0; alignment: start;
    
    Rectangle {
        width: 100%; height: 22px;
        background: transparent;
        
        HorizontalBox {
            spacing: 10px; padding: 0; alignment: start;
            Rectangle {
                width: 18px; height: 18px; border-radius: 3px; border-width: 1px; 
                border-color: Theme.border; background: Theme.input-bg;
                y: (parent.height - self.height) / 2;
                if (root.checked) : Rectangle { x: 3px; y: 3px; width: 12px; height: 12px; background: Theme.brand-blue; border-radius: 2px; }
            }
            BasicText { text: root.text; vertical-alignment: center; }
        }
        TouchArea { 
            mouse-cursor: pointer;
            clicked => { 
                root.checked = !root.checked;
                root.toggled(); // Optionnel
            }
        }
    }
}
export component CustomRadioButton inherits HorizontalBox {
    in-out property <string> text;
    in-out property <bool> checked;
    callback toggled; 
    spacing: 10px; padding: 0; alignment: start;
    Rectangle {
        width: 100%; height: 22px; background: transparent;
        HorizontalBox {
            spacing: 10px; padding: 0; alignment: start;
            Rectangle {
                width: 18px; height: 18px; border-radius: 9px; border-width: 1px; border-color: Theme.border; background: Theme.input-bg;
                y: (parent.height - self.height) / 2;
                if (root.checked) : Rectangle { x: 4px; y: 4px; width: 10px; height: 10px; background: Theme.brand-blue; border-radius: 5px; }
            }
            BasicText { text: root.text; vertical-alignment: center; }
        }
        TouchArea { 
            mouse-cursor: pointer;
            clicked => { if (!root.checked) { root.toggled(); } } 
        }
    }
}
export component CustomComboBox inherits Rectangle {
    in-out property <[string]> model; in-out property <string> current-value; in-out property <int> current-index: 0;
    height: 35px; border-width: 1px; border-color: Theme.brand-blue; border-radius: 4px; background: Theme.input-bg;
    HorizontalBox { padding-left: 10px; padding-right: 10px; BasicText { text: root.current-value; vertical-alignment: center; } 
        BasicText { text: "▼"; font-size: 10px; horizontal-alignment: end; vertical-alignment: center; color: Theme.brand-blue; } }
    touch := TouchArea { clicked => { popup.show(); } }
    popup := PopupWindow { x: 0; y: root.height; width: root.width;
        Rectangle { background: Theme.surface; border-width: 1px; border-color: Theme.brand-blue; border-radius: 4px; 
            VerticalBox { padding: 5px; spacing: 0;
                for val[idx] in root.model : Rectangle { height: 30px; background: i-ta.has-hover ? Theme.brand-blue : transparent; border-radius: 2px;
                    BasicText { x: 10px; text: val; vertical-alignment: center; color: i-ta.has-hover ? white : Theme.text-main;}
                    i-ta := TouchArea { clicked => { root.current-value = val; root.current-index = idx; } }
}   }   }   }   }
export component LangSelectorBox inherits Rectangle {
    in-out property <[string]> model; in-out property <string> current-value; callback selected(string);
    height: 35px; border-width: 1px; border-color: Theme.border; border-radius: 4px; background: Theme.input-bg;
    HorizontalBox { padding-left: 10px; padding-right: 10px; BasicText { text: root.current-value; vertical-alignment: center; } 
        BasicText { text: "▼"; font-size: 10px; horizontal-alignment: end; vertical-alignment: center; color: Theme.brand-blue;}}
    touch := TouchArea { mouse-cursor: pointer; clicked => { popup.show(); } }
    popup := PopupWindow { x: 0; y: root.height; width: root.width;
        Rectangle { background: Theme.surface; border-width: 1px; border-color: Theme.brand-blue; border-radius: 4px;
            VerticalBox { padding: 5px; spacing: 0;
                for val in root.model : Rectangle {
                    height: 30px; background: i-ta.has-hover ? Theme.brand-blue : transparent; border-radius: 2px;
                    BasicText { x: 10px; text: val; vertical-alignment: center; color: i-ta.has-hover ? white : Theme.text-main;}
                    i-ta := TouchArea { mouse-cursor: pointer; clicked => { root.current-value = val; root.selected(val); } }
}   }   }   }   }
export component CustomButton inherits Rectangle {
    in-out property <string> text; callback clicked;
    width: 150px; height: 45px; border-radius: 8px; border-width: 1px; border-color: Theme.border;
    background: ta.pressed ? Theme.border : ta.has-hover ? (Theme.is_dark ? #353c48 : #e2e8f0) : Theme.surface;
    ButtonText { text: root.text; horizontal-alignment: center; vertical-alignment: center; width: 90%; }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}
export component SelectButton inherits Rectangle {
    in-out property <string> text; callback clicked;
    width: 150px; height: 45px; border-radius: 8px; border-width: 1px; border-color: Theme.border;
    background: ta.pressed ? Theme.border : ta.has-hover ? (Theme.is_dark ? #353c48 : #e2e8f0) : Theme.surface;
    ButtonText { text: root.text; horizontal-alignment: start; vertical-alignment: center; width: 90%; }
    ta := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}
// --- MAIN BUTTON ---
export component BlueButton inherits Rectangle {
    in-out property <string> text; callback clicked;
    width: 150px; height: 45px; border-radius: 8px;
    background: touch.pressed ? Theme.pressed-blue : touch.has-hover ? Theme.hover-blue : Theme.brand-blue;
    Text { text: root.text; color: white; font-weight: 900; horizontal-alignment: center; vertical-alignment: center; }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}
export component NavButton inherits Rectangle {
    in-out property <string> text; callback clicked;
    width: 30px; height: 35px; border-radius: 4px; border-width: 1px; border-color: Theme.border;
    background: touch.pressed ? Theme.border : touch.has-hover ? (Theme.is_dark ? #353c48 : #e2e8f0) : Theme.surface;
    Text { text: root.text; color: Theme.text-main; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
    touch := TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}
export component ClassicBlueLink inherits Rectangle {
    in-out property <string> text; callback clicked;
    width: txt.width; height: txt.height + 2px;
    txt := Text { text: root.text; color: #3498db; font-size: 14px; }
    Rectangle { y: parent.height; height: 1px; width: 100%; background: #3498db; }
    TouchArea { mouse-cursor: pointer; clicked => { root.clicked(); } }
}
